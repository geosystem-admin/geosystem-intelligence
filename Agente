<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IMMORTAL AGENT — Herramienta GX · GEOSYSTEM</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Inter:wght@300;400;500&display=swap');

:root {
  --bg:#020408; --surface:#080f1a; --panel:#0c1520; --border:#0d2035;
  --accent:#36f4d0; --accent2:#fbbf24; --accent3:#0ea5e9;
  --green:#4ade80; --yellow:#ffd600; --orange:#f97316;
  --text:#c8dae8; --dim:#4a6278; --glow:rgba(54,244,208,0.15);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,212,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;}
.container{position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:16px;}

/* HEADER */
header{text-align:center;padding:32px 0 24px;border-bottom:1px solid var(--border);margin-bottom:20px;}
.logo-line{display:flex;align-items:center;justify-content:center;gap:14px;margin-bottom:6px;}
.logo-icon{width:52px;height:52px;background:linear-gradient(135deg,var(--accent),var(--accent3));border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;box-shadow:0 0 30px var(--glow);}
h1{font-family:'Orbitron',monospace;font-size:2rem;font-weight:900;background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:3px;}
.tagline{font-family:'Share Tech Mono',monospace;color:var(--dim);font-size:0.75rem;letter-spacing:2px;margin-top:4px;}
.status-bar{display:flex;align-items:center;justify-content:center;gap:12px;margin-top:14px;flex-wrap:wrap;}
.status-pill{display:flex;align-items:center;gap:6px;background:var(--panel);border:1px solid var(--border);border-radius:20px;padding:4px 12px;font-size:0.68rem;font-family:'Share Tech Mono',monospace;color:var(--dim);}
.dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,255,136,0.4);}50%{opacity:.7;box-shadow:0 0 0 6px rgba(0,255,136,0);}}

/* API BANNER */
.api-banner{background:var(--panel);border:1px solid rgba(255,214,0,0.3);border-radius:12px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.api-banner.active{border-color:rgba(0,255,136,0.35);}

/* MODULE HEADERS */
.module-header{display:flex;align-items:center;gap:12px;padding:14px 18px;border-radius:12px;margin-bottom:4px;cursor:pointer;border:1px solid var(--border);background:var(--surface);transition:all .2s;user-select:none;}
.module-header:hover{border-color:var(--accent);background:rgba(0,212,255,0.04);}
.module-num{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-size:0.9rem;font-weight:700;flex-shrink:0;}
.m1 .module-num{background:rgba(0,212,255,0.15);color:var(--accent);border:1px solid rgba(0,212,255,0.3);}
.m2 .module-num{background:rgba(123,47,255,0.15);color:#b77fff;border:1px solid rgba(123,47,255,0.3);}
.m3 .module-num{background:rgba(255,60,172,0.15);color:var(--accent2);border:1px solid rgba(255,60,172,0.3);}
.module-title{flex:1;}
.module-name{font-family:'Orbitron',monospace;font-size:0.75rem;letter-spacing:2px;}
.m1 .module-name{color:var(--accent);}
.m2 .module-name{color:#b77fff;}
.m3 .module-name{color:var(--accent2);}
.module-sub{font-size:0.68rem;color:var(--dim);font-family:'Share Tech Mono',monospace;margin-top:3px;}
.module-arrow{font-size:0.7rem;color:var(--dim);transition:transform .2s;}
.module-arrow.open{transform:rotate(90deg);}

.module-body{display:none;background:var(--surface);border:1px solid var(--border);border-top:none;border-radius:0 0 12px 12px;padding:20px;margin-bottom:16px;}
.module-body.open{display:block;}

/* TABS inside modules */
.subtabs{display:flex;gap:4px;background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:3px;margin-bottom:16px;overflow-x:auto;}
.subtab{flex:1;min-width:100px;padding:8px 12px;border:none;background:transparent;color:var(--dim);font-family:'Orbitron',monospace;font-size:0.58rem;letter-spacing:1px;cursor:pointer;border-radius:7px;transition:all .2s;white-space:nowrap;}
.subtab.active{background:rgba(0,212,255,0.12);color:var(--accent);border:1px solid rgba(0,212,255,0.25);}
.subtab:hover:not(.active){background:var(--surface);color:var(--text);}
.subpanel{display:none;}.subpanel.active{display:block;}

/* CARDS */
.card{background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:14px;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent3));}
.card-header{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.card-icon{width:32px;height:32px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:16px;background:var(--surface);border:1px solid var(--border);}
.card-title{font-family:'Orbitron',monospace;font-size:0.72rem;color:var(--accent);letter-spacing:2px;}

/* INPUTS */
.input-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;}
@media(max-width:580px){.input-grid{grid-template-columns:1fr;}}
.input-group{display:flex;flex-direction:column;gap:5px;}
label{font-size:0.68rem;color:var(--dim);font-family:'Share Tech Mono',monospace;letter-spacing:1px;}
input,select,textarea{background:var(--surface);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Inter',sans-serif;font-size:0.83rem;padding:9px 11px;outline:none;transition:border-color .2s;width:100%;}
input:focus,select:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(0,212,255,0.1);}
textarea{resize:vertical;min-height:75px;}
select option{background:var(--panel);}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:7px;padding:10px 20px;border:none;border-radius:9px;font-family:'Orbitron',monospace;font-size:0.65rem;letter-spacing:2px;cursor:pointer;transition:all .2s;}
.btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent3));color:#000;font-weight:700;box-shadow:0 4px 18px rgba(0,212,255,0.3);}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 26px rgba(0,212,255,0.4);}
.btn-m2{background:linear-gradient(135deg,var(--accent3),var(--accent2));color:#fff;}
.btn-m2:hover{transform:translateY(-2px);}
.btn-m3{background:linear-gradient(135deg,var(--accent2),var(--orange));color:#fff;}
.btn-m3:hover{transform:translateY(-2px);}
.btn-secondary{background:var(--panel);border:1px solid var(--border);color:var(--accent);}
.btn-secondary:hover{border-color:var(--accent);background:rgba(0,212,255,0.06);}
.btn:disabled{opacity:.45;cursor:not-allowed;transform:none!important;}
.btn-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;}

/* OUTPUT */
.output-box{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:14px;font-family:'Share Tech Mono',monospace;font-size:0.76rem;line-height:1.75;color:var(--text);min-height:60px;white-space:pre-wrap;word-break:break-word;}
.output-box.loading{color:var(--dim);animation:flicker 1.5s infinite;}
@keyframes flicker{0%,100%{opacity:1}50%{opacity:.5}}

/* TAGS */
.tags-wrap{display:flex;flex-wrap:wrap;gap:7px;margin-top:8px;}
.tag-chip{padding:4px 11px;border-radius:20px;font-size:0.7rem;font-family:'Share Tech Mono',monospace;cursor:pointer;transition:all .15s;border:1px solid;}
.tag-chip.viral{background:rgba(255,60,172,.1);border-color:rgba(255,60,172,.4);color:var(--accent2);}
.tag-chip.trending{background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.4);color:var(--accent);}
.tag-chip.niche{background:rgba(0,255,136,.1);border-color:rgba(0,255,136,.4);color:var(--green);}
.tag-chip:hover{transform:scale(1.06);}

/* ALGO BARS */
.algo-item{margin-bottom:12px;}
.algo-row{display:flex;justify-content:space-between;font-size:0.73rem;margin-bottom:4px;}
.progress-wrap{background:var(--panel);border-radius:6px;height:5px;overflow:hidden;}
.progress-fill{height:100%;border-radius:6px;background:linear-gradient(90deg,var(--accent),var(--accent3));transition:width .6s ease;}

/* METRICS */
.metrics-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:18px;}
.metric-card{background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:14px;text-align:center;}
.metric-val{font-family:'Orbitron',monospace;font-size:1.5rem;font-weight:700;color:var(--accent);line-height:1;}
.metric-lbl{font-size:0.62rem;color:var(--dim);font-family:'Share Tech Mono',monospace;letter-spacing:1px;margin-top:4px;}
.metric-change{font-size:0.68rem;margin-top:4px;}
.up{color:var(--green);} .dn{color:var(--accent2);}

/* AB TEST CARDS */
.ab-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:12px;}
@media(max-width:580px){.ab-grid{grid-template-columns:1fr;}}
.ab-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px;}
.ab-label{font-family:'Orbitron',monospace;font-size:0.65rem;letter-spacing:2px;margin-bottom:8px;}
.ab-a .ab-label{color:var(--accent);}
.ab-b .ab-label{color:var(--accent2);}

/* COMMENTS */
.comment-item{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:12px;margin-bottom:8px;}
.comment-meta{font-size:0.65rem;color:var(--dim);font-family:'Share Tech Mono',monospace;margin-bottom:5px;}
.comment-text{font-size:0.8rem;color:var(--text);line-height:1.5;}

/* CALENDAR */
.cal-week{margin-bottom:14px;}
.cal-week-title{font-family:'Orbitron',monospace;font-size:0.68rem;color:var(--accent);letter-spacing:2px;margin-bottom:8px;}
.cal-video{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:10px 14px;margin-bottom:6px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.cal-date{background:var(--panel);border:1px solid var(--border);border-radius:7px;padding:5px 9px;text-align:center;min-width:44px;}
.cal-day-num{font-family:'Orbitron',monospace;font-size:1rem;color:var(--accent);}
.cal-day-name{font-size:0.55rem;color:var(--dim);font-family:'Share Tech Mono',monospace;}

/* BADGES */
.badge{display:inline-block;padding:2px 7px;border-radius:10px;font-size:0.58rem;font-family:'Share Tech Mono',monospace;letter-spacing:1px;}
.badge-g{background:rgba(0,255,136,.12);color:var(--green);border:1px solid rgba(0,255,136,.3);}
.badge-y{background:rgba(255,214,0,.12);color:var(--yellow);border:1px solid rgba(255,214,0,.3);}
.badge-r{background:rgba(255,60,172,.12);color:var(--accent2);border:1px solid rgba(255,60,172,.3);}

.flex-between{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.copy-btn{background:none;border:1px solid var(--border);border-radius:6px;color:var(--dim);padding:4px 10px;font-size:0.62rem;cursor:pointer;font-family:'Share Tech Mono',monospace;transition:all .15s;}
.copy-btn:hover{border-color:var(--accent);color:var(--accent);}
.sep{border:none;border-top:1px solid var(--border);margin:16px 0;}
.tip{background:rgba(0,212,255,.05);border:1px solid rgba(0,212,255,.2);border-radius:9px;padding:10px 14px;font-size:0.76rem;color:var(--text);line-height:1.6;margin-top:10px;}
.tip strong{color:var(--accent);}
.spinner{display:inline-block;width:14px;height:14px;border:2px solid rgba(0,212,255,.3);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;}
@keyframes spin{to{transform:rotate(360deg)}}
.section-label{font-family:'Share Tech Mono',monospace;font-size:0.68rem;color:var(--dim);letter-spacing:1px;margin-bottom:6px;}
</style>
</head>
<body>
<div class="container">

<!-- HEADER -->
<header>
  <div class="logo-line">
    <div class="logo-icon">🔥</div>
    <h1>IMMORTAL EMITTER</h1>
  </div>
  <p class="tagline">AGENTE DE PRODUCCIÓN · GEOPOLÍTICA · IA · NUEVO ORDEN MUNDIAL · GEOSYSTEM</p>
  <p style="font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:rgba(0,212,255,0.4);margin-top:6px;letter-spacing:1px;">
    <a href="terminal.html" style="color:rgba(54,244,208,0.5);text-decoration:none;">← Volver a la Terminal</a>
  </p>
  <div class="status-bar">
    <div class="status-pill"><span class="dot"></span> GEOSYSTEM · AGENTE ACTIVO</div>
    <div class="status-pill">🔭 MÓDULO VIGILANCIA</div>
    <div class="status-pill">⚗️ ALQUIMIA_NARRATIVA</div>
    <div class="status-pill">♾️ INMORTALIDAD_ALGORITMO</div>
  </div>
</header>

<!-- GX GATE -->
<div id="gx-gate" style="background:var(--panel);border:1px solid rgba(251,191,36,.3);border-radius:12px;padding:20px;margin-bottom:18px;text-align:center;">
  <div style="font-size:28px;margin-bottom:8px;">🔑</div>
  <div style="font-family:'Orbitron',monospace;font-size:0.8rem;color:#fbbf24;letter-spacing:3px;margin-bottom:6px;">ACCESO EXCLUSIVO GX</div>
  <div style="font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--dim);margin-bottom:14px;letter-spacing:1px;">Ingresa tu clave GX para acceder al Agente de Producción</div>
  <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;">
    <input id="gx-key-input" type="text" placeholder="GX-YYYY-MM-DD-NOMBRE" 
      style="font-family:'Share Tech Mono',monospace;font-size:0.85rem;background:#000;border:1px solid #78350f;color:#fbbf24;padding:10px 14px;outline:none;text-transform:uppercase;letter-spacing:1px;width:260px;"
      onkeydown="if(event.key==='Enter')validateGX()">
    <button onclick="validateGX()" 
      style="background:#fbbf24;color:#000;font-family:'Orbitron',monospace;font-size:0.65rem;font-weight:900;letter-spacing:2px;padding:10px 18px;border:none;cursor:pointer;">
      SINCRONIZAR ▶
    </button>
  </div>
  <div style="margin-top:10px;font-family:'Share Tech Mono',monospace;font-size:0.6rem;color:var(--dim);">
    ¿Sin clave? <a href="terminal.html" style="color:#fbbf24;text-decoration:none;">Suscríbete en la Terminal ↗</a>
  </div>
</div>

<!-- AGENT CONTENT — hidden until GX validated -->
<div id="agent-content" style="display:none;">
<div class="api-banner active" id="api-banner">
  <div style="font-size:18px">✅</div>
  <div style="flex:1">
    <div style="font-family:'Orbitron',monospace;font-size:0.68rem;color:var(--green);letter-spacing:2px;">SISTEMA ACTIVO · CLAVE GX VERIFICADA</div>
    <div style="font-family:'Share Tech Mono',monospace;font-size:0.62rem;color:var(--dim);margin-top:3px;" id="gx-user-info">Cargando...</div>
  </div>
  <div id="key-status" style="font-family:'Share Tech Mono',monospace;font-size:0.68rem;color:var(--green);">⬤ ACTIVO</div>
</div>

<!-- ══════════════════════════════════════
     MÓDULO 1 — VIGILANCIA
══════════════════════════════════════ -->
<div class="module-header m1" onclick="toggleModule('m1')">
  <div class="module-num">01</div>
  <div class="module-title">
    <div class="module-name">🔭 MÓDULO DE VIGILANCIA</div>
    <div class="module-sub">Vigilancia de tendencias geopolíticas · Análisis competencia · Detección de huecos narrativos en LATAM</div>
  </div>
  <div class="module-arrow" id="arrow-m1">▶</div>
</div>
<div class="module-body" id="body-m1">

  <div class="subtabs">
    <button class="subtab active" onclick="showSub('m1','tendencias')">📡 TENDENCIAS</button>
    <button class="subtab" onclick="showSub('m1','competencia')">🕵️ COMPETENCIA</button>
    <button class="subtab" onclick="showSub('m1','hueco')">🎯 HUECO NARRATIVO</button>
    <button class="subtab" onclick="showSub('m1','tags')">🏷️ TAGS VIRALES</button>
  </div>

  <!-- TENDENCIAS -->
  <div class="subpanel active" id="m1-tendencias">
    <div class="card">
      <div class="card-header"><div class="card-icon">📡</div><span class="card-title">ESCÁNER DE TENDENCIAS EN TIEMPO REAL</span></div>
      <div class="input-grid">
        <div class="input-group">
          <label>SUBTEMA A VIGILAR</label>
          <input id="t-subtema" placeholder="ej: CBDC en LATAM, guerra China-EEUU, Bitcoin 2026..." />
        </div>
        <div class="input-group">
          <label>REGIÓN / MERCADO</label>
          <select id="t-region">
            <option>Colombia / LATAM (principal)</option>
            <option>Español global</option>
            <option>Venezuela</option>
            <option>México</option>
            <option>Argentina</option>
          </select>
        </div>
      </div>
      <button class="btn btn-primary" onclick="runVigilancia()">📡 ESCANEAR TENDENCIAS</button>
    </div>
    <div class="card">
      <div class="flex-between"><span class="card-title" style="color:var(--accent)">REPORTE DE TENDENCIAS</span><button class="copy-btn" onclick="copyEl('out-tendencias')">COPIAR</button></div>
      <div class="output-box" id="out-tendencias">Ejecuta el escáner para ver tendencias activas...</div>
    </div>
  </div>

  <!-- COMPETENCIA -->
  <div class="subpanel" id="m1-competencia">
    <div class="card">
      <div class="card-header"><div class="card-icon">🕵️</div><span class="card-title">ANÁLISIS DE METADATOS DE COMPETENCIA</span></div>
      <div class="input-grid">
        <div class="input-group">
          <label>TEMA DEL VIDEO VIRAL</label>
          <input id="c-tema" placeholder="ej: El petróleo llegó a $100, Trump vs China en LATAM..." />
        </div>
        <div class="input-group">
          <label>VISTAS APROXIMADAS</label>
          <select id="c-vistas">
            <option>100K - 500K</option>
            <option>500K - 1M</option>
            <option>1M - 5M</option>
            <option>+5M (viral masivo)</option>
          </select>
        </div>
      </div>
      <div class="input-group" style="margin-bottom:12px">
        <label>TÍTULO DEL VIDEO VIRAL (opcional)</label>
        <input id="c-titulo" placeholder="Pega el título exacto del video que quieres analizar" />
      </div>
      <button class="btn btn-primary" onclick="runCompetencia()">🔬 ANALIZAR METADATOS</button>
    </div>
    <div class="card">
      <div class="flex-between"><span class="card-title" style="color:var(--accent)">ANÁLISIS DE COMPETENCIA</span><button class="copy-btn" onclick="copyEl('out-competencia')">COPIAR</button></div>
      <div class="output-box" id="out-competencia">Ingresa datos del video a analizar...</div>
    </div>
  </div>

  <!-- HUECO NARRATIVO -->
  <div class="subpanel" id="m1-hueco">
    <div class="card">
      <div class="card-header"><div class="card-icon">🎯</div><span class="card-title">DETECTOR DE HUECO NARRATIVO</span></div>
      <div class="input-group" style="margin-bottom:10px">
        <label>¿CUÁL ES TU "VERDAD ETERNA" / MANIFIESTO?</label>
        <textarea id="h-manifiesto" placeholder="El mundo está en la transición de poder más grande en 500 años. La IA, el dinero programable y la geopolítica están redefiniendo todo — y LATAM no está preparada. Geosystem existe para mostrar el tablero real."></textarea>
      </div>
      <div class="input-group" style="margin-bottom:12px">
        <label>TEMA DE TENDENCIA ACTUAL</label>
        <input id="h-tendencia" placeholder="ej: El dinero digital va a controlar tu vida" />
      </div>
      <button class="btn btn-primary" onclick="runHueco()">🎯 ENCONTRAR EL HUECO</button>
    </div>
    <div class="card">
      <div class="flex-between"><span class="card-title" style="color:var(--accent)">HUECO IDENTIFICADO</span><button class="copy-btn" onclick="copyEl('out-hueco')">COPIAR</button></div>
      <div class="output-box" id="out-hueco">Define tu manifiesto y el tema para encontrar dónde encajas...</div>
    </div>
  </div>

  <!-- TAGS -->
  <div class="subpanel" id="m1-tags">
    <div class="card">
      <div class="card-header"><div class="card-icon">🏷️</div><span class="card-title">GENERADOR DE TAGS VIRALES</span></div>
      <div class="input-grid">
        <div class="input-group">
          <label>TEMA DEL VIDEO</label>
          <input id="tag-topic" placeholder="ej: Geopolítica LATAM, CBDC, Bitcoin, Nuevo Orden Mundial..." />
        </div>
        <div class="input-group">
          <label>CANTIDAD</label>
          <select id="tag-count">
            <option value="15">15 tags</option>
            <option value="30" selected>30 tags (recomendado)</option>
            <option value="500">Máximo (500 chars)</option>
          </select>
        </div>
      </div>
