async function ai(prompt, sys='') {
  const key = getKey();
  if (!key) { alert('⚠️ Pega tu API Key en el campo de arriba y presiona GUARDAR'); throw new Error('Sin key'); }
  const body = { model:MODEL, max_tokens:1000, messages:[{role:'user',content:prompt}] };
  if (sys) body.system = sys;
  const res = await fetch(API_URL, {
    method:'POST',
    headers:{'Content-Type':'application/json','x-api-key':key,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
    body:JSON.stringify(body)
  });
  const data = await res.json();
  if (data.error) throw new Error(data.error.message);
  return data.content?.[0]?.text || 'Error en respuesta.';
}

